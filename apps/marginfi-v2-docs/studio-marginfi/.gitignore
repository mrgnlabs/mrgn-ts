# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
/node_modules
/.pnp
.pnp.js

# Compiled Sanity Studio (build output)
/dist

# Temporary Sanity runtime files (generated by CLI at dev runtime)
/.sanity

# Logs and debug output
/logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing coverage directories
/coverage

# Misc system artifacts
.DS_Store
*.pem
*.swp  # Temporary files generated by editors like Vim

# TypeScript build artifacts
*.tsbuildinfo

# Dotenv and similar local-only files
.env
.env.local
.env.*