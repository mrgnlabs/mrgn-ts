# General information
# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# IDE settings and project-specific environment configurations
.env*
.idea

# Dependencies-related files and folders
node_modules
.pnp
.pnp.js

# Test coverage output
coverage

# Next.js build files and static output
.next/
out/
build
dist

# Miscellaneous system and sensitive files to ignore
.DS_Store
*.pem

# Debug logs generated by npm and pnpm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Local environment files
.env.local
.env.development.local
.env.test.local
.env.production.local

# TurboRepo-related files
.turbo

# IDE configurations
.vscode

# Zone.Identifier files (security zone attachment metadata on some systems)
*Zone.Identifier
**/*Zone.Identifier